# The Mirror Platform — client env. Copy to .env.local and fill in.
# Only the PUBLIC client values belong here. The service-role key and the DB
# password are server secrets — they live in Supabase function secrets, NEVER
# in the client bundle or any committed file.
VITE_SUPABASE_URL=https://YOUR-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx_or_legacy_anon_jwt
