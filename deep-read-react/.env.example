# The Deep Read — frontend env (Vite).
# VITE_ vars are embedded in the client bundle at build time. The Supabase
# PUBLISHABLE key is meant for the browser (RLS is the security boundary).
# In Netlify, set these as build environment variables.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-side only (NEVER VITE_-prefixed, NEVER shipped to the browser).
# SUPABASE_SECRET_KEY=sb_secret_...        # admin / server reads (bypasses RLS)
# SUPABASE_ACCESS_TOKEN=sbp_...            # Management API: run migrations
# SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
