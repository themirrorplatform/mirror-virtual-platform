# The Deep Read — frontend env (Vite).
# VITE_ vars are embedded in the client bundle at build time. The Supabase anon
# key is PUBLISHABLE (RLS is the security boundary), so it is safe in the browser.
# In Netlify, set these as build environment variables.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (never VITE_-prefixed, never shipped to the browser).
# Used by scripts/apply-migration.mjs to run migrations via the Management API.
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
